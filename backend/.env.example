# Bank Verification & Payment API Keys
# Replace with your actual API keys from Paystack and Flutterwave

# Paystack API Keys (Primary provider)
# Get from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_actual_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_actual_paystack_public_key
PAYSTACK_CALLBACK_URL=http://localhost:3001/api/payments/callback

# Flutterwave API Keys (Backup provider)
# Get from: https://dashboard.flutterwave.com/settings/api
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_actual_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_actual_flutterwave_public

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Enable debug mode
DEBUG=false

MONGODB_URI=mongodb://localhost:27017/mavenpay
JWT_SECRET=your_development_jwt_secret_key_at_least_32_characters_long_1234
JWT_REFRESH_SECRET=your_development_jwt_refresh_secret_at_least_32_characters_long_5678

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM_NAME=SznPay
EMAIL_FROM_ADDRESS=no-reply@dotpay.ng

FRONTEND_URL=http://localhost:5173

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=SznPay
TERMII_CHANNEL=generic

CORS_ORIGIN=http://localhost:5173,http://localhost:5174,capacitor://localhost,http://localhost

# Postgres Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mavenpay_ledger
PG_USER=postgres
PG_PASSWORD=postgres
PG_SSL=false
