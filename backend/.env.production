# ============================================
# SznPay Production Environment Variables
# ============================================
# IMPORTANT: Never commit this file to version control!
# Copy this to .env and fill in your actual values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3001
API_BASE_URL=https://api.mavenpay.com

# ============================================
# DATABASE
# ============================================
# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://mavenpay_user:YOUR_MONGODB_PASSWORD@cluster0.xxxxx.mongodb.net/mavenpay?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Secrets (Generate strong random strings - 64+ characters)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_SUPER_SECURE_JWT_SECRET_HERE_64_CHARS_MINIMUM
JWT_REFRESH_SECRET=YOUR_SUPER_SECURE_REFRESH_SECRET_HERE_64_CHARS_MINIMUM

# Session Secret
SESSION_SECRET=YOUR_SESSION_SECRET_HERE

# Encryption Key for sensitive data
ENCRYPTION_KEY=YOUR_32_BYTE_ENCRYPTION_KEY_HERE

# ============================================
# PAYMENT GATEWAYS
# ============================================
# Paystack (Primary - Nigerian Payment Gateway)
# Get from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_YOUR_ACTUAL_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_live_YOUR_ACTUAL_PAYSTACK_PUBLIC_KEY
PAYSTACK_CALLBACK_URL=https://api.mavenpay.com/api/payments/callback

# Flutterwave (Backup Payment Gateway)
# Get from: https://dashboard.flutterwave.com/settings/api
FLUTTERWAVE_SECRET_KEY=FLWSECK-YOUR_ACTUAL_FLUTTERWAVE_SECRET
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-YOUR_ACTUAL_FLUTTERWAVE_PUBLIC
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST-YOUR_ENCRYPTION_KEY

# ============================================
# SMS & EMAIL SERVICES
# ============================================
# Termii (Nigerian SMS Gateway)
# Get from: https://termii.com
TERMII_API_KEY=YOUR_TERMII_API_KEY
TERMII_SENDER_ID=SznPay

# Twilio (Alternative SMS)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email Service)
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@mavenpay.com
SENDGRID_FROM_NAME=SznPay

# ============================================
# REDIS (Caching & Session Management)
# ============================================
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@redis-xxxxx.cloud.redislabs.com:12345
REDIS_HOST=redis-xxxxx.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ============================================
# BVN VERIFICATION
# ============================================
# Paystack BVN API (included in Paystack)
# Or use dedicated BVN verification service
BVN_VERIFICATION_API_KEY=YOUR_BVN_API_KEY

# ============================================
# STOCK MARKET DATA (For Investment Features)
# ============================================
# Nigerian Stock Exchange API
NSE_API_KEY=YOUR_NSE_API_KEY
NSE_API_URL=https://api.nse.com.ng

# Alpha Vantage (Global Stocks)
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_KEY

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry (Error Tracking)
# Get from: https://sentry.io
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# LogDNA / DataDog (Logging)
LOGDNA_KEY=YOUR_LOGDNA_KEY

# ============================================
# CLOUD STORAGE (For Document Uploads)
# ============================================
# AWS S3
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=eu-west-1
AWS_S3_BUCKET=mavenpay-documents

# Cloudinary (Alternative)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_SECRET

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=https://mavenpay.com,https://www.mavenpay.com
ALLOWED_ORIGINS=https://mavenpay.com,https://www.mavenpay.com,https://app.mavenpay.com

# ============================================
# WEBHOOK SECRETS
# ============================================
PAYSTACK_WEBHOOK_SECRET=YOUR_PAYSTACK_WEBHOOK_SECRET
FLUTTERWAVE_WEBHOOK_SECRET=YOUR_FLUTTERWAVE_WEBHOOK_SECRET

# ============================================
# COMPLIANCE & REGULATORY
# ============================================
# CBN Reporting
CBN_REPORTING_API_KEY=YOUR_CBN_API_KEY
NFIU_REPORTING_ENDPOINT=https://nfiu.gov.ng/api/reports

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_MFA=true
ENABLE_DEVICE_FINGERPRINTING=true
ENABLE_VELOCITY_CHECKS=true
ENABLE_INVESTMENT_FEATURES=false
ENABLE_CRYPTO_TRADING=false

# ============================================
# LIMITS & THRESHOLDS
# ============================================
# Transaction Limits (in Naira)
TIER1_DAILY_LIMIT=50000
TIER2_DAILY_LIMIT=200000
TIER3_DAILY_LIMIT=5000000

# AML Thresholds
AML_SINGLE_TRANSACTION_THRESHOLD=5000000
AML_DAILY_AGGREGATE_THRESHOLD=10000000

# ============================================
# MOBILE APP
# ============================================
# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=mavenpay-xxxxx
FIREBASE_PRIVATE_KEY=YOUR_FIREBASE_PRIVATE_KEY
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@mavenpay.iam.gserviceaccount.com

# ============================================
# AI/ML SERVICES
# ============================================
# OpenAI / Claude (For AI Features)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# xAI Grok (Current AI Service)
XAI_GROK_API_KEY=YOUR_GROK_API_KEY

# ============================================
# DEVELOPMENT/DEBUG
# ============================================
DEBUG=false
LOG_LEVEL=info
ENABLE_API_DOCS=false

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENCRYPTION_KEY=YOUR_BACKUP_ENCRYPTION_KEY
BACKUP_S3_BUCKET=mavenpay-backups
