# Frontend Environment (Vite)

# Backend API Configuration
# Set to your backend server URL that will proxy API calls
VITE_BACKEND_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001/api
VITE_USE_BACKEND_PROXY=true

# Public API Keys (optional fallback; do NOT add secrets here)
# Get from https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
# Get from https://dashboard.flutterwave.com/settings/api
VITE_FLW_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key_here

# Environment
NODE_ENV=development